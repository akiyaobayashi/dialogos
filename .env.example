# Dialogos production environment

# OpenAI
OPENAI_API_KEY=sk-proj_xxxx
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=620
OPENAI_TEMPERATURE=0.9

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Supabase Anon Key（フロントエンド用・公開して問題ない）
# Supabase Dashboard → Settings → API → anon/public
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Public app URL
APP_URL=https://your-dialogos-domain.vercel.app

# Resend（メールアドレス同期機能）
# https://resend.com で無料登録 → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx
# 送信元アドレス（Resendでドメイン認証済みのアドレス）
RESEND_FROM=Dialogos <noreply@yourdomain.com>

# 管理者パネル（/admin.html）のアクセスシークレット
# 推測されにくい長いランダム文字列を設定すること
ADMIN_SECRET=your-admin-secret-change-this

# Optional
FREE_COUNT=10
RATE_LIMIT_PER_MINUTE=10
MAX_RECENT_MESSAGES=20
MAX_FREE_RECENT_MESSAGES=8
